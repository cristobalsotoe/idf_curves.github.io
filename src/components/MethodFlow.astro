---
const steps = [
  { n: '01', title: 'Observaciones', text: 'Series horarias de 161 estaciones pluviométricas como referencia local.' },
  { n: '02', title: 'Datos grillados', text: 'Cinco productos satelitales y de reanálisis evaluados de manera consistente.' },
  { n: '03', title: 'Extremos', text: 'Máximos anuales calculados para 11 duraciones entre 1 y 72 horas.' },
  { n: '04', title: 'Curvas IDF', text: 'Estimaciones para seis períodos de retorno, desde 2 hasta 100 años.' },
];
---
<div class="method-flow">
  {steps.map((step, index) => (
    <article class="method-step reveal" style={`transition-delay: ${index * 70}ms`}>
      <div class="method-step__number">{step.n}</div>
      <div>
        <h3>{step.title}</h3>
        <p>{step.text}</p>
      </div>
    </article>
  ))}
</div>

<style>
  .method-flow { position: relative; display: grid; grid-template-columns: repeat(4, 1fr); }
  .method-flow::before { content: ''; position: absolute; left: 5%; right: 5%; top: 2.05rem; height: 2px; background: linear-gradient(90deg, var(--navy-800), var(--red-500), var(--rain-500)); }
  .method-step { position: relative; padding: 0 clamp(1rem, 2.5vw, 2.2rem); }
  .method-step__number { position: relative; z-index: 1; width: 4.2rem; height: 4.2rem; display: grid; place-items: center; margin-bottom: 1.5rem; border: 2px solid var(--navy-800); border-radius: 50%; color: var(--navy-800); background: white; font-family: var(--font-display); font-size: 1.15rem; font-weight: 800; }
  .method-step:nth-child(2) .method-step__number { border-color: var(--red-500); color: var(--red-500); }
  .method-step:nth-child(3) .method-step__number { border-color: var(--rain-700); color: var(--rain-700); }
  .method-step h3 { margin-bottom: 0.7rem; font-size: 1.5rem; }
  .method-step p { color: var(--muted); font-size: 0.93rem; }
  @media (max-width: 860px) { .method-flow { grid-template-columns: 1fr 1fr; gap: 3rem 1rem; } .method-flow::before { display: none; } }
  @media (max-width: 520px) { .method-flow { grid-template-columns: 1fr; } .method-step { display: grid; grid-template-columns: auto 1fr; gap: 1.2rem; padding: 0; } .method-step__number { width: 3.6rem; height: 3.6rem; margin: 0; } }
</style>
