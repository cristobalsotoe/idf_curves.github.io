---
const metrics = [
  { number: '161', label: 'estaciones pluviométricas' },
  { number: '5', label: 'productos de precipitación' },
  { number: '11', label: 'duraciones entre 1 y 72 horas' },
  { number: '6', label: 'períodos de retorno entre 2 y 100 años' },
  { number: '17–56° S', label: 'cobertura latitudinal aproximada' },
  { number: '2001–2021', label: 'período principal de análisis' },
];
---
<section class="metric-strip" aria-label="Alcance del estudio">
  <div class="container metric-grid">
    {metrics.map((metric, index) => (
      <div class="metric reveal" style={`transition-delay: ${index * 80}ms`}>
        <strong>{metric.number}</strong>
        <span>{metric.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .metric-strip { border-block: 1px solid var(--line); background: white; }
  .metric-grid { display: grid; grid-template-columns: repeat(6, 1fr); }
  .metric { min-height: 170px; display: grid; align-content: center; gap: 0.25rem; padding: 2rem clamp(1rem, 3vw, 2rem); border-right: 1px solid var(--line); }
  .metric:first-child { border-left: 1px solid var(--line); }
  .metric strong { color: var(--navy-800); font-family: var(--font-display); font-size: clamp(2.05rem, 3.5vw, 4.2rem); letter-spacing: -0.04em; line-height: 1; }
  .metric:nth-child(2) strong { color: var(--red-500); }.metric:nth-child(3) strong { color: var(--rain-700); }
  .metric span { max-width: 180px; color: var(--muted); font-size: 0.76rem; font-weight: 700; line-height: 1.35; text-transform: uppercase; }
  @media (max-width: 1050px) { .metric-grid { grid-template-columns: repeat(3, 1fr); } .metric { border-bottom: 1px solid var(--line); } }
  @media (max-width: 620px) { .metric-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
