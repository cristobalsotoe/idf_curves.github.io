---
const appUrl = 'https://csoto.shinyapps.io/IDF_Curves/';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Curvas IDF Chile',
  description: 'Plataforma interactiva de curvas intensidad-duración-frecuencia de alta resolución para Chile.',
  applicationCategory: 'ScientificApplication',
  operatingSystem: 'Web',
  url: 'https://curvasidf.cl/',
};
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#153A5F" />
    <meta name="description" content="Plataforma interactiva de curvas IDF de alta resolución para Chile." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://curvasidf.cl/" />
    <meta property="og:title" content="Plataforma interactiva — Curvas IDF Chile" />
    <meta property="og:description" content="Explore curvas de intensidad, duración y frecuencia para Chile." />
    <meta property="og:image" content="https://curvasidf.cl/og.png" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    <title>Plataforma interactiva — Curvas IDF Chile</title>
  </head>
  <body>
    <div class="loader" data-loader role="status" aria-live="polite">
      <div class="loader__content">
        <img src="/brand/idf-logo-negative.svg" alt="Curvas IDF Chile" width="320" height="320" />
        <div class="loader__line" aria-hidden="true"><span></span></div>
        <p>Cargando plataforma de curvas IDF</p>
        <a href="/home">Visitar el sitio editorial</a>
      </div>
    </div>
    <iframe
      src={appUrl}
      title="Plataforma interactiva de curvas IDF para Chile"
      allow="fullscreen"
      loading="eager"
      data-app-frame
    ></iframe>
    <noscript>
      <div class="fallback">Active JavaScript o <a href={appUrl}>abra la plataforma directamente</a>.</div>
    </noscript>
    <script>
      const frame = document.querySelector('[data-app-frame]');
      const loader = document.querySelector('[data-loader]');
      const startedAt = performance.now();
      frame?.addEventListener('load', () => {
        const remaining = Math.max(0, 1400 - (performance.now() - startedAt));
        window.setTimeout(() => loader?.classList.add('is-hidden'), remaining);
      });
      window.setTimeout(() => loader?.classList.add('is-delayed'), 10000);
    </script>
  </body>
</html>

<style>
  * { box-sizing: border-box; }
  html, body { width: 100%; height: 100%; margin: 0; overflow: hidden; background: #03070b; }
  iframe { position: fixed; inset: 0; width: 100%; height: 100%; border: 0; background: white; }
  .loader { position: fixed; inset: 0; z-index: 2; display: grid; place-content: center; justify-items: center; overflow: hidden; color: #cbe0e5; background: radial-gradient(circle at center, #10273a 0, #07131e 38%, #03070b 72%); font-family: "Helvetica Neue", Helvetica, Arial, Calibri, sans-serif; transition: opacity .7s ease, visibility .7s ease; }
  .loader::before { content: ''; position: absolute; width: min(72vw, 720px); aspect-ratio: 1; border: 1px solid rgb(121 173 187 / .2); border-radius: 50%; box-shadow: 0 0 0 55px rgb(121 173 187 / .045), 0 0 0 110px rgb(121 173 187 / .025); }
  .loader__content { position: relative; z-index: 2; display: grid; justify-items: center; gap: 1.35rem; }
  .loader.is-hidden { opacity: 0; visibility: hidden; pointer-events: none; }
  .loader img { width: clamp(220px, 30vw, 340px); height: auto; filter: drop-shadow(0 18px 34px rgb(0 0 0 / .55)); animation: logo-arrival 1s cubic-bezier(.22, 1, .36, 1) both; }
  .loader p { margin: 0; color: white; font-size: clamp(.68rem, 1vw, .82rem); font-weight: 700; letter-spacing: .16em; text-align: center; text-transform: uppercase; }
  .loader a { color: white; font-size: .75rem; text-underline-offset: .25em; opacity: 0; transition: opacity .3s ease; }
  .loader.is-delayed a { opacity: 1; }
  .loader__line { width: 180px; height: 2px; overflow: hidden; background: rgb(203 224 229 / .18); }
  .loader__line span { display: block; width: 55%; height: 100%; background: linear-gradient(90deg, #79adbb, #d64045); animation: load 1.5s ease-in-out infinite alternate; }
  .fallback { position: fixed; z-index: 3; inset: auto 1rem 1rem; padding: 1rem; color: white; background: #153a5f; font-family: system-ui; text-align: center; }
  @keyframes load { from { transform: translateX(-100%); } to { transform: translateX(180%); } }
  @keyframes logo-arrival { from { opacity: 0; transform: scale(.84); } to { opacity: 1; transform: scale(1); } }
  @media (max-width: 520px) { .loader::before { width: 90vw; } .loader__content { gap: 1rem; } .loader img { width: min(68vw, 280px); } .loader p { max-width: 82vw; line-height: 1.5; } }
  @media (prefers-reduced-motion: reduce) { .loader__line span { animation: none; width: 100%; } .loader img { animation: none; } }
</style>
