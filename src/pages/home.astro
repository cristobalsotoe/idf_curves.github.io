---
import { getCollection } from 'astro:content';
import EditorialLayout from '../layouts/EditorialLayout.astro';
import HeroIDF from '../components/HeroIDF.astro';
import MetricStrip from '../components/MetricStrip.astro';
import MethodFlow from '../components/MethodFlow.astro';
import FindingsScrolly from '../components/FindingsScrolly.astro';
import PaperCitation from '../components/PaperCitation.astro';
import AuthorGrid from '../components/AuthorGrid.astro';
import NotesGrid from '../components/NotesGrid.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
---
<EditorialLayout title="Curvas IDF Chile" description="Curvas de intensidad, duración y frecuencia de alta resolución para comprender las precipitaciones extremas en Chile.">
  <HeroIDF />
  <MetricStrip />

  <section class="section intro-section">
    <div class="container intro-grid">
      <div class="section-heading reveal">
        <p class="eyebrow">El propósito</p>
        <h2>Convertir datos complejos en información utilizable</h2>
      </div>
      <div class="intro-copy reveal">
        <p class="lead">Las curvas IDF relacionan cuánta lluvia puede caer, durante cuánto tiempo y con qué frecuencia estadística. Son una herramienta central para dimensionar obras hidráulicas y estudiar eventos extremos.</p>
        <p>Este proyecto integra observaciones y productos grillados para ampliar la cobertura espacial disponible en Chile, con un método documentado y una plataforma abierta para explorar resultados.</p>
        <a class="text-link" href="/metodologia">Comprender la metodología →</a>
      </div>
    </div>
  </section>

  <section class="section section--mist">
    <div class="container">
      <div class="section-heading reveal">
        <p class="eyebrow">Del dato a la curva</p>
        <h2>Un flujo reproducible en cuatro etapas</h2>
        <p class="lead">El análisis combina evidencia instrumental con productos de cobertura continua, respetando una misma secuencia de estimación.</p>
      </div>
      <MethodFlow />
    </div>
  </section>

  <section class="section findings-section">
    <div class="container">
      <div class="section-heading reveal">
        <p class="eyebrow">Resultados principales</p>
        <h2>La intensidad extrema también dibuja el territorio</h2>
        <p class="lead">Los patrones observados no siguen únicamente el gradiente de precipitación media. La duración y el relieve cambian la lectura.</p>
      </div>
      <FindingsScrolly />
    </div>
  </section>

  <section class="platform-callout section--navy">
    <div class="platform-curves" aria-hidden="true"><i></i><i></i><i></i></div>
    <div class="container platform-callout__inner">
      <div>
        <p class="eyebrow">Exploración interactiva</p>
        <h2>Del mapa a la curva, directamente en el navegador</h2>
      </div>
      <div class="platform-callout__copy">
        <p class="lead">Seleccione ubicaciones, duraciones y períodos de retorno para consultar las estimaciones disponibles.</p>
        <a class="button button--light" href="/">Abrir plataforma</a>
      </div>
    </div>
  </section>

  <section class="section section--mist">
    <div class="container">
      <div class="section-heading reveal">
        <p class="eyebrow">Evidencia revisada por pares</p>
        <h2>La investigación detrás de la plataforma</h2>
      </div>
      <PaperCitation />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading reveal">
        <p class="eyebrow">Equipo</p>
        <h2>Investigación colaborativa</h2>
      </div>
      <AuthorGrid />
    </div>
  </section>

  <section class="section section--mist">
    <div class="container">
      <div class="notes-heading reveal">
        <div>
          <p class="eyebrow">Notas y recursos</p>
          <h2>Claves para usar las curvas IDF</h2>
        </div>
        <a class="text-link" href="/notas">Ver todas las notas →</a>
      </div>
      <NotesGrid notes={notes} />
    </div>
  </section>

  <section class="section history-preview">
    <div class="container history-preview__inner">
      <div class="history-year" aria-hidden="true">2026</div>
      <div class="history-preview__copy reveal">
        <p class="eyebrow">Historia del proyecto</p>
        <h2>De una investigación universitaria a una plataforma de curvas IDF abierta</h2>
        <p class="lead">El proyecto ha evolucionado a través de investigación, desarrollo de software, publicación académica y comunicación pública.</p>
        <a class="button button--secondary" href="/historia">Recorrer la historia</a>
      </div>
    </div>
  </section>
</EditorialLayout>

<style>
  .intro-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(3rem, 9vw, 9rem); }
  .intro-copy { display: grid; gap: 1.3rem; align-content: start; color: var(--muted); }
  .findings-section { padding-bottom: clamp(4rem, 8vw, 7rem); }
  .platform-callout { position: relative; overflow: hidden; padding-block: clamp(5rem, 10vw, 9rem); }
  .platform-callout__inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1.15fr .85fr; gap: clamp(3rem, 9vw, 9rem); align-items: end; }
  .platform-callout__copy { display: grid; justify-items: start; gap: 1.6rem; }
  .platform-curves i { position: absolute; width: 68vw; height: 50vw; right: -25vw; bottom: -36vw; border: 2px solid rgb(121 173 187 / .35); border-radius: 50%; }
  .platform-curves i:nth-child(2) { width: 55vw; height: 42vw; right: -18vw; bottom: -30vw; border-color: rgb(214 64 69 / .5); }
  .platform-curves i:nth-child(3) { width: 42vw; height: 35vw; right: -10vw; bottom: -25vw; }
  .notes-heading { display: flex; margin-bottom: clamp(2rem, 5vw, 4rem); align-items: end; justify-content: space-between; gap: 2rem; }
  .notes-heading h2 { margin-top: 1rem; }
  .history-preview { overflow: hidden; }
  .history-preview__inner { position: relative; min-height: 470px; display: grid; grid-template-columns: 1fr 1fr; align-items: center; }
  .history-year { color: var(--mist); font-family: var(--font-display); font-size: clamp(8rem, 23vw, 22rem); font-weight: 900; letter-spacing: -.08em; line-height: .7; transform: translateX(-8%); }
  .history-preview__copy { position: relative; display: grid; gap: 1.4rem; justify-items: start; }
  @media (max-width: 760px) { .intro-grid, .platform-callout__inner, .history-preview__inner { grid-template-columns: 1fr; } .history-preview__inner { padding-top: 5rem; } .history-year { position: absolute; top: 0; left: 0; } .notes-heading { align-items: start; flex-direction: column; } }
</style>
