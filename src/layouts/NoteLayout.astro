---
import EditorialLayout from './EditorialLayout.astro';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  authors: string[];
  category: string;
  tags: string[];
}
const { title, description, publishedAt, updatedAt, authors, category, tags } = Astro.props;
const dateFormat = new Intl.DateTimeFormat('es-CL', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' });
---
<EditorialLayout title={title} description={description} type="article" publishedAt={publishedAt}>
  <header class="note-hero">
    <div class="container note-hero__inner">
      <a class="breadcrumbs" href="/notas">← Todas las notas</a>
      <p class="eyebrow">{category}</p>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      <div class="note-meta">
        <span>{authors.join(' · ')}</span>
        <span>Publicado el {dateFormat.format(publishedAt)}</span>
        {updatedAt && <span>Actualizado el {dateFormat.format(updatedAt)}</span>}
      </div>
    </div>
  </header>
  <article class="container note-body">
    <div class="prose"><slot /></div>
    <aside class="note-tags" aria-label="Etiquetas">
      {tags.map((tag) => <span>{tag}</span>)}
    </aside>
  </article>
</EditorialLayout>

<style>
  .note-hero { padding: clamp(7rem, 13vw, 11rem) 0 5rem; background: var(--mist); }
  .note-hero__inner { display: grid; gap: 1.2rem; max-width: 960px; }
  .note-hero h1 { font-size: clamp(3rem, 7vw, 6rem); }
  .note-meta { display: flex; flex-wrap: wrap; gap: 0.5rem 1.5rem; color: var(--muted); font-size: 0.86rem; font-weight: 600; }
  .note-body { display: grid; grid-template-columns: minmax(0, 760px) 1fr; gap: clamp(2rem, 8vw, 7rem); align-items: start; padding-block: clamp(4rem, 8vw, 7rem); }
  .note-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; position: sticky; top: 7rem; }
  .note-tags span { padding: 0.35rem 0.65rem; border: 1px solid var(--line); border-radius: 999px; color: var(--navy-700); font-size: 0.75rem; font-weight: 700; }
  @media (max-width: 840px) { .note-body { grid-template-columns: 1fr; } .note-tags { position: static; } }
</style>
